# Development / testing profile (separate bot token from production)
APP_ENV=development
HOST=0.0.0.0
PORT=8000

DATABASE_URL=sqlite+aiosqlite:///./course_hub_dev.db

# Development/testing Telegram bot token
BOT_TOKEN=
BACKEND_URL=http://localhost:8000

ADMIN_USERNAME=admin
ADMIN_PASSWORD=dev-admin
ADMIN_SESSION_SECRET=dev-session-secret

PAYMENT_PROVIDER=simulated
PAYMENT_API_KEY=
PAYMENT_SECRET_KEY=dev-webhook-secret
PAYMENT_CURRENCY=USD
LAVA_ENV=production
PAYMENT_LINK_MODE=direct

LOG_LEVEL=DEBUG

SUPPORTED_LANGUAGES=uk,en
DEFAULT_LANGUAGE=uk
SEARCH_SUGGESTION_MIN_CHARS=3
SEARCH_SUGGESTION_LIMIT=5
PARSER_REQUEST_TIMEOUT_SECONDS=10
