# Course Hub configuration (copy to .env and fill real values; never commit .env)

# Run profile: development | production
APP_ENV=development

# HTTP server
HOST=0.0.0.0
PORT=8000

# Database (SQLite phase 1; switch to PostgreSQL by changing this URL only)
# SQLite:     sqlite+aiosqlite:///./course_hub.db
# PostgreSQL: postgresql+asyncpg://user:password@host:5432/course_hub
DATABASE_URL=sqlite+aiosqlite:///./course_hub.db

# Telegram bot
BOT_TOKEN=
# Public base/callback URL the bot/payments use
BACKEND_URL=http://localhost:8000

# First admin account (seeded on initial run; password is stored hashed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Session secret for the admin panel
ADMIN_SESSION_SECRET=change-me-too

# Payments
PAYMENT_PROVIDER=simulated
PAYMENT_API_KEY=
PAYMENT_SECRET_KEY=
PAYMENT_CURRENCY=USD

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
